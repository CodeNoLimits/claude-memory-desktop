#!/usr/bin/env bash
# nova-nofocus — STOP au vol de focus, immédiat + permanent. À coller dans N'IMPORTE quel terminal.
# 1) cache TOUT DE SUITE les navigateurs d'agents visibles  2) (ré)arme le garde permanent focus-guard.
# JAMAIS "Google Chrome Canary" (= David) ni Antigravity. Zéro dépendance, marche dans tout shell.
set +e

AGENTS='{"Google Chrome","Google Chrome Beta","Chromium","Google Chrome for Testing"}'

# 1) HIDE IMMÉDIAT (osascript System Events — rend le focus à l'app de David instantanément)
osascript -e "tell application \"System Events\" to set visible of (every process whose name is in $AGENTS) to false" >/dev/null 2>&1

# 2) (RE)ARMER le garde permanent (le re-cache en continu, même après reboot)
UID_=$(id -u)
launchctl kickstart -k "gui/${UID_}/com.dreamnova.focus-guard" >/dev/null 2>&1 \
  || launchctl bootstrap "gui/${UID_}" "$HOME/Library/LaunchAgents/com.dreamnova.focus-guard.plist" >/dev/null 2>&1

# 3) ÉTAT (preuve)
echo "🛡️  nova-nofocus appliqué :"
for P in "Google Chrome" "Google Chrome Beta" "Chromium" "Google Chrome for Testing"; do
  if pgrep -f "$P" >/dev/null 2>&1; then
    V=$(osascript -e "tell application \"System Events\" to get visible of process \"$P\"" 2>/dev/null)
    echo "   • $P → visible=$V"
  fi
done
G=$(launchctl list 2>/dev/null | grep -c "com.dreamnova.focus-guard")
echo "   • garde focus-guard actif: $([ "$G" -ge 1 ] && echo OUI || echo NON) · Canary (David) jamais touché"
