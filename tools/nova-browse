    return d


def v_click(a):
    page, _ = resolve_target(tab_id=a.tab)
    t = attach(page)
    try:
        _write_current(page["id"])
        if a.ref is not None:
            raw = t.eval(_js_click_ref(a.ref))
        elif a.text:
            raw = t.eval(_js_click_text(a.text))
        elif a.selector:
            raw = t.eval(_js_click_selector(a.selector))
        elif a.xy:
            x, y = [int(v) for v in a.xy.split(",")]
            t.click_xy(x, y)
            raw = json.dumps({"clicked": True, "on": f"xy {x},{y}"})
        else:
            return {"ok": False, "error": "préciser --ref / --text / --selector / --xy"}
        time.sleep(a.wait)
        d = json.loads(raw) if isinstance(raw, str) else {"clicked": False}
        d["ok"] = bool(d.get("clicked"))
        d["tab"] = page["id"]
        if not d["ok"]:
            d["hint"] = "élément introuvable — re-snapshot, ou essaie --text / Gemini `act`. 2 échecs = STOP."
    finally:
        t.close_ws()
        hide()
    return d


def v_type(a):
