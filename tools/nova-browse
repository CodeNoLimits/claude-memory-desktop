    "ArrowDown": ("ArrowDown", "ArrowDown", 40, None), "ArrowUp": ("ArrowUp", "ArrowUp", 38, None),
    "ArrowLeft": ("ArrowLeft", "ArrowLeft", 37, None), "ArrowRight": ("ArrowRight", "ArrowRight", 39, None),
