def v_act(a):
    page, _ = resolve_target(tab_id=a.tab)
    shot = os.path.join(STATE_DIR, "act.png")
    t = attach(page)
    try:
        _write_current(page["id"])
        t.screenshot(shot)
        size = t.eval("JSON.stringify({w:window.innerWidth,h:window.innerHeight})")
        dims = json.loads(size) if isinstance(size, str) else {"w": 0, "h": 0}
    finally:
        t.close_ws()
        hide()
    prompt = (f"L'image fait {dims.get('w')}x{dims.get('h')} px (viewport). "
              f"Tâche : {a.instruction}. "
              "Renvoie UNIQUEMENT du JSON {\"x\":<pixel>,\"y\":<pixel>,\"found\":true,\"label\":\"<élément>\"} "
              "donnant le centre exact de l'élément à cliquer. Si rien ne correspond, {\"found\":false}.")
    g = gemini_vision(shot, prompt, want_json=True)
    if not g.get("ok"):
        return g
    try:
        coords = json.loads(g["answer"])
    except Exception:
        return {"ok": False, "error": "Gemini n'a pas renvoyé de coords JSON", "raw": g.get("answer")}
    if not coords.get("found"):
        return {"ok": False, "found": False, "hint": "Gemini ne voit pas la cible. 2 échecs = STOP."}
    page2, _ = resolve_target(tab_id=page["id"])
    t2 = attach(page2)
    try:
        t2.click_xy(int(coords["x"]), int(coords["y"]))
        time.sleep(a.wait)
    finally:
        t2.close_ws()
        hide()
    return {"ok": True, "tab": page["id"], "clicked_xy": [coords.get("x"), coords.get("y")],
            "label": coords.get("label")}


def v_wait(a):
    page, _ = resolve_target(tab_id=a.tab)
    deadline = time.time() + a.ms / 1000.0
    t = attach(page)
    try:
        _write_current(page["id"])
        while time.time() < deadline:
            if a.text:
                hit = t.eval("document.body && document.body.innerText.includes(%s)" % json.dumps(a.text))
                if hit is True:
                    return {"ok": True, "tab": page["id"], "matched": "text"}
            elif a.selector:
                hit = t.eval("!!document.querySelector(%s)" % json.dumps(a.selector))
                if hit is True:
                    return {"ok": True, "tab": page["id"], "matched": "selector"}
            else:
                time.sleep(a.ms / 1000.0)
                return {"ok": True, "tab": page["id"], "matched": "delay"}
            time.sleep(0.4)
        return {"ok": False, "tab": page["id"], "error": "timeout", "hint": "condition jamais remplie"}
    finally:
        t.close_ws()
        hide()


def v_close(a):
    if not a.tab:
        return {"ok": False, "error": "--tab <id> requis (ne ferme jamais WA/LI par erreur)"}
    try:
        # /json/close/<id> renvoie du TEXTE brut ("Target is closing"), pas du JSON → urlopen direct.
        urllib.request.urlopen(CDP + "/json/close/" + a.tab, timeout=5).read()
        if _read_current() == a.tab:
            _write_current("")
        return {"ok": True, "closed": a.tab}
    except Exception as e:
        return {"ok": False, "error": str(e)}


def v_find(a):
    """Suis-je authentifié sur ce domaine ? Délègue au script canonique si présent, sinon heuristique cookies."""
    script = os.path.expanduser("~/etz-chaim/scripts/cdp_cookie_inspect.py")
    if os.path.exists(script):
        r = subprocess.run([sys.executable, script, a.domain], capture_output=True, text=True, timeout=30)
        return {"ok": r.returncode == 0, "domain": a.domain, "exit": r.returncode,
                "out": (r.stdout or r.stderr).strip()[:500]}
    # fallback : compte les cookies du profil pour ce domaine
    found = 0
    for db in glob.glob(os.path.join(PROFILE, "*", "Cookies")) + [os.path.join(PROFILE, "Default", "Cookies")]:
        if os.path.exists(db):
            try:
                import sqlite3
                con = sqlite3.connect(f"file:{db}?mode=ro", uri=True)
                found += con.execute("SELECT COUNT(*) FROM cookies WHERE host_key LIKE ?",
                                     ("%" + a.domain + "%",)).fetchone()[0]
                con.close()
            except Exception:
                pass
    return {"ok": found > 0, "domain": a.domain, "cookies": found,
            "hint": "0 cookie → demander à David d'ouvrir Chrome Beta une fois sur ce site, ou dn-secret"}


