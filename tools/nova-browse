def build_parser():
    p = argparse.ArgumentParser(prog="nova-browse", description="Contrôleur navigateur headless universel (CDP Chrome Beta).")
    sub = p.add_subparsers(dest="cmd", required=True)

    def common(sp):
        # --tab et --pretty sur CHAQUE sous-commande (forme naturelle : nova-browse <verbe> --tab X --pretty)
        sp.add_argument("--tab", help="id d'onglet cible (sinon onglet courant mémorisé)")
        sp.add_argument("--pretty", action="store_true", help="sortie lisible au lieu de JSON")
        return sp

    common(sub.add_parser("status")).set_defaults(fn=v_status)

    sp = common(sub.add_parser("tabs")); sp.add_argument("--select"); sp.set_defaults(fn=v_tabs)

    sp = common(sub.add_parser("goto")); sp.add_argument("url"); sp.add_argument("--reuse", action="store_true")
    sp.add_argument("--wait", type=float, default=3.5); sp.set_defaults(fn=v_goto)

    sp = common(sub.add_parser("read")); sp.add_argument("--links", action="store_true")
    sp.add_argument("--max", type=int, default=4000); sp.set_defaults(fn=v_read)

    common(sub.add_parser("snapshot")).set_defaults(fn=v_snapshot)

    sp = common(sub.add_parser("click")); sp.add_argument("--ref", type=int); sp.add_argument("--text")
    sp.add_argument("--selector"); sp.add_argument("--xy"); sp.add_argument("--wait", type=float, default=1.0)
    sp.set_defaults(fn=v_click)

    sp = common(sub.add_parser("type")); sp.add_argument("text"); sp.add_argument("--ref", type=int)
    sp.add_argument("--selector"); sp.add_argument("--wait", type=float, default=0.3); sp.set_defaults(fn=v_type)

    sp = common(sub.add_parser("fill")); sp.add_argument("--selector", required=True); sp.add_argument("value")
    sp.set_defaults(fn=v_fill)

    sp = common(sub.add_parser("key")); sp.add_argument("name"); sp.add_argument("--wait", type=float, default=0.5)
    sp.set_defaults(fn=v_key)

    sp = common(sub.add_parser("eval")); sp.add_argument("expr"); sp.set_defaults(fn=v_eval)

    sp = common(sub.add_parser("screenshot")); sp.add_argument("out", nargs="?"); sp.set_defaults(fn=v_screenshot)

    sp = common(sub.add_parser("see")); sp.add_argument("--ask"); sp.set_defaults(fn=v_see)

    sp = common(sub.add_parser("act")); sp.add_argument("instruction"); sp.add_argument("--wait", type=float, default=1.5)
    sp.set_defaults(fn=v_act)

    sp = common(sub.add_parser("wait")); sp.add_argument("--text"); sp.add_argument("--selector")
    sp.add_argument("--ms", type=int, default=10000); sp.set_defaults(fn=v_wait)

    common(sub.add_parser("close")).set_defaults(fn=v_close)

    sp = common(sub.add_parser("find")); sp.add_argument("domain"); sp.set_defaults(fn=v_find)

    sp = common(sub.add_parser("upload")); sp.add_argument("files", nargs="+")
    sp.add_argument("--selector", default="input[type=file]"); sp.set_defaults(fn=v_upload)

    return p


def main():
    args = build_parser().parse_args()
    try:
        result = args.fn(args)
    except Exception as e:
        result = {"ok": False, "error": str(e), "type": type(e).__name__,
                  "hint": "Chrome Beta down ? `nova-browse status`. CDP=127.0.0.1:9222. 2 échecs = STOP → DAVID_ACTION_REQUIRED."}
    if args.pretty:
        if result.get("ok"):
            for k, v in result.items():
                if k == "ok":
                    continue
                if isinstance(v, (list, dict)):
                    print(f"{k}: {json.dumps(v, ensure_ascii=False)[:2000]}")
                else:
                    print(f"{k}: {v}")
        else:
            print("ERREUR:", result.get("error"), "|", result.get("hint", ""))
    else:
        print(json.dumps(result, ensure_ascii=False))
    sys.exit(0 if result.get("ok") else 1)


if __name__ == "__main__":
    main()
